# Backend runtime
JWT_SECRET_KEY=replace-with-a-long-random-secret
# JWT_SECRET is also accepted for compatibility.
# JWT_SECRET=replace-with-a-long-random-secret

# Seeded admin account. INITIAL_ADMIN_PASSWORD is required only when the
# database must seed a missing admin user.
INITIAL_ADMIN_EMAIL=admin@stockoptimizer.local
INITIAL_ADMIN_PASSWORD=ChangeMe123!
DEMO_USER_PASSWORD=DemoPass123!

# SQLite/bootstrap behavior
STOCK_OPTIMIZER_DB_PATH=database/stock_optimizer.db
AUTO_BOOTSTRAP_DB=true
RESET_DB_ON_START=false
REFRESH_CSV_ON_START=false

# Frontend CORS origins accepted by FastAPI when bypassing Next rewrites.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Optional ML service bridge. The backend falls back to generated ML CSV output
# when this service is not running.
ML_SERVICE_BASE_URL=http://localhost:8001
ML_SERVICE_TIMEOUT_SECONDS=5
ML_PROCESSED_DATA_DIR=../../ml/data/processed
